{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.sw.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "WebWorker"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["vite-plugin-pwa/client"],
    "skipLibCheck": true,
    "noEmit": true,
    "moduleDetection": "force",
    "erasableSyntaxOnly": true
  },
  "include": ["src/sw.ts"]
}
